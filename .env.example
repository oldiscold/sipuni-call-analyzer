# Groq API для транскрибации (Whisper) и анализа (Llama 3.3 70B)
# Получить БЕСПЛАТНО: https://console.groq.com
GROQ_API_KEY=gsk_...

# Telegram Bot для отправки фидбека
# Создать бота: @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC...

# ID чата для отправки уведомлений
# Узнать: @userinfobot или @getmyid_bot
TELEGRAM_CHAT_ID=123456789

# API-ключ Сипуни для авторизации вебхуков
# Получить в личном кабинете Сипуни
SIPUNI_API_KEY=your_sipuni_api_key
